    "preview":  "npx serve . -p 5000",
    "seed:export": "node scripts/export-seed.js"
  },
  "devDependencies": {
    "html-validate": "^8.0.0",
    "serve":         "^14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "fewsion", "creator-economy", "india", "ugc", "marketplace",
    "influencer-marketing", "static-site"
  ],
