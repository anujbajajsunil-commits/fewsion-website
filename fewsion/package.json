{
  "name": "fewsion-website",
  "version": "1.0.0",
  "description": "Fewsion — India's first performance-first creator marketplace. Marketing website.",
  "private": true,
  "homepage": "https://fewsion.in",
  "repository": {
    "type": "git",
    "url":  "https://github.com/YOUR_USERNAME/fewsion-website.git"
  },
  "scripts": {
    "dev":      "npx serve . -p 3000 --no-clipboard",
